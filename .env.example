# Cible env vars. Copy to .env.local and fill in.
# See PRD §11 (Tech stack).

# Anthropic — generators + verifier claim extraction
ANTHROPIC_API_KEY=

# OpenAI — cross-family critic (gpt-5) + text-embedding-3-small (verifier)
OPENAI_API_KEY=

# Helicone — proxy for both Anthropic and OpenAI; provides observability
HELICONE_API_KEY=

# Upstash Redis — rate limiting + trace storage
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
